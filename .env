# 复制此文件为 .env，填入真实凭据（.env 不提交到 git）
ZHIPU_API_KEY=your_zhipu_api_key_here

# ── SMTP 凭据 ──────────────────────────────────────────────────────────────
# 设置你的邮箱账号和密码（或 App Password）。
#
# 常见邮件服务商配置参考：
#   Gmail        → smtp_host: smtp.gmail.com    smtp_port: 465   smtp_security: ssl
#                  （需开启两步验证并生成 App Password）
#   Outlook/365  → smtp_host: smtp.office365.com smtp_port: 587  smtp_security: starttls
#   Yahoo        → smtp_host: smtp.mail.yahoo.com smtp_port: 465 smtp_security: ssl
#   自定义       → 填写你的 SMTP 服务器地址、端口和安全模式
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# 收件人列表，多个邮箱用逗号分隔（覆盖 config.yaml 中的 recipients）
SMTP_RECIPIENTS=recipient@example.com

# 通知模式：
#   obsidian（默认）：只做 vault/ Git 同步，不发邮件
#   email：只发邮件（PDF + Markdown 双附件），不产生 GitHub Commit（保持仓库整洁）
#   both：既发邮件，也做 vault/ Git 同步
# GitHub Actions 中通过 Repository Variable NOTIFY_MODE 控制（默认 obsidian）
NOTIFY_MODE=obsidian
