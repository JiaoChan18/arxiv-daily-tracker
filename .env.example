# 复制此文件为 .env，填入真实凭据（.env 不提交到 git）
ZHIPU_API_KEY=your_zhipu_api_key_here
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# 通知模式：
#   obsidian（默认）：只做 vault/ Git 同步，不发邮件
#   email：只发邮件（PDF + Markdown 双附件），不产生 GitHub Commit（保持仓库整洁）
#   both：既发邮件，也做 vault/ Git 同步
# GitHub Actions 中通过 Repository Variable NOTIFY_MODE 控制（默认 obsidian）
NOTIFY_MODE=obsidian
